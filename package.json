{
  "name": "@workspace/vivgrid-openai-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenAI-compatible VivGrid chat proxy with API key rotation.",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
