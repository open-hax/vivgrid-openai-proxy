    "test": "pnpm run build && node --test dist/tests/*.test.js"
  },
  "dependencies": {
    "fastify": "^4.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
